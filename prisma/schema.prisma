generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Attendance {
  id         Int       @id @default(autoincrement())
  teacher_id Int?
  user_id    Int?
  student_id Int
  isPresent  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  date       DateTime?
  group_id   Int?
  Groups     Groups?   @relation(fields: [group_id], references: [id])
  Students   Students  @relation(fields: [student_id], references: [id])
  Teachers   Teachers? @relation(fields: [teacher_id], references: [id])
  User       User?     @relation(fields: [user_id], references: [id])
}

model Courses {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  description    String
  price          Int
  duration_month Int
  duration_hours Int
  status         Status   @default(active)
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now())
  Groups         Groups[]
}

model Groups {
  id            Int             @id @default(autoincrement())
  name          String
  description   String?
  course_id     Int
  room_id       Int
  start_date    DateTime
  end_date      DateTime
  week_day      String[]
  start_time    String
  max_students  Int             @default(20)
  status        GroupStatus     @default(planned)
  created_at    DateTime        @default(now())
  updated_at    DateTime        @default(now())
  Attendance    Attendance[]
  Courses       Courses         @relation(fields: [course_id], references: [id])
  Rooms         Rooms           @relation(fields: [room_id], references: [id])
  HomeWork      HomeWork[]
  Lesson        Lesson[]
  StudentGroup  StudentGroup[]
  TeachersGroup TeachersGroup[]
  Videos        Videos[]
}

model HomeWork {
  id             Int              @id @default(autoincrement())
  lesson_id      Int
  user_id        Int?
  teacher_id     Int?
  group_id       Int
  title          String
  file           String?
  description    String?
  created_at     DateTime         @default(now())
  updated_at     DateTime         @default(now())
  video_url      String?
  Groups         Groups           @relation(fields: [group_id], references: [id])
  Lesson         Lesson           @relation(fields: [lesson_id], references: [id])
  Teachers       Teachers?        @relation(fields: [teacher_id], references: [id])
  User           User?            @relation(fields: [user_id], references: [id])
  HomeWorkAnswer HomeWorkAnswer[]
}

model HomeWorkAnswer {
  id             Int              @id @default(autoincrement())
  student_id     Int
  homwork_id     Int
  title          String
  file           String?
  created_at     DateTime         @default(now())
  updated_at     DateTime         @default(now())
  HomeWork       HomeWork         @relation(fields: [homwork_id], references: [id])
  Students       Students         @relation(fields: [student_id], references: [id])
  HomeWorkResult HomeWorkResult[]
}

model HomeWorkResult {
  id                 Int            @id @default(autoincrement())
  techer_id          Int?
  user_id            Int?
  homework_answer_id Int
  grade              Int
  title              String
  created_at         DateTime       @default(now())
  updated_at         DateTime       @default(now())
  HomeWorkAnswer     HomeWorkAnswer @relation(fields: [homework_answer_id], references: [id])
  Teachers           Teachers?      @relation(fields: [techer_id], references: [id])
  User               User?          @relation(fields: [user_id], references: [id])
}

model Lesson {
  id          Int        @id @default(autoincrement())
  group_id    Int
  teacher_id  Int?
  user_id     Int?
  topic       String?
  description String?
  status      Status     @default(active)
  created_at  DateTime   @default(now())
  updated_at  DateTime
  type        String?
  date        DateTime?
  HomeWork    HomeWork[]
  Groups      Groups     @relation(fields: [group_id], references: [id])
  Teachers    Teachers?  @relation(fields: [teacher_id], references: [id])
  User        User?      @relation(fields: [user_id], references: [id])
  Videos      Videos[]
}

model Rooms {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  capacity   Int      @default(1)
  status     Status   @default(active)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  Groups     Groups[]
}

model StudentGroup {
  id         Int      @id @default(autoincrement())
  student_id Int
  group_id   Int
  status     Status   @default(active)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  Groups     Groups   @relation(fields: [group_id], references: [id])
  Students   Students @relation(fields: [student_id], references: [id])

  @@unique([student_id, group_id])
}

model Students {
  id             Int              @id @default(autoincrement())
  full_name      String
  email          String           @unique
  password       String
  phone          String           @unique
  address        String?
  photo          String?
  birth_date     DateTime
  status         StudentStatus    @default(active)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @default(now())
  Attendance     Attendance[]
  HomeWorkAnswer HomeWorkAnswer[]
  StudentGroup   StudentGroup[]
}

model Teachers {
  id             Int              @id @default(autoincrement())
  full_name      String
  email          String           @unique
  password       String
  phone          String           @unique
  address        String?
  photo          String?
  status         Status           @default(active)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @default(now())
  Attendance     Attendance[]
  HomeWork       HomeWork[]
  HomeWorkResult HomeWorkResult[]
  Lesson         Lesson[]
  TeachersGroup  TeachersGroup[]
  Videos         Videos[]
}

model TeachersGroup {
  id         Int      @id @default(autoincrement())
  teacher_id Int
  group_id   Int
  created_at DateTime @default(now())
  Groups     Groups   @relation(fields: [group_id], references: [id])
  Teachers   Teachers @relation(fields: [teacher_id], references: [id])

  @@unique([teacher_id, group_id])
}

model User {
  id             Int              @id @default(autoincrement())
  full_name      String
  email          String           @unique
  password       String
  role           UserRole
  phone          String           @unique
  address        String?
  photo          String?
  status         Status           @default(active)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @default(now())
  Attendance     Attendance[]
  HomeWork       HomeWork[]
  HomeWorkResult HomeWorkResult[]
  Lesson         Lesson[]
  Videos         Videos[]
}

model Videos {
  id          Int       @id @default(autoincrement())
  lesson_id   Int?
  group_id    Int
  teacher_id  Int?
  user_id     Int?
  title       String
  video_url   String
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now())
  Groups      Groups    @relation(fields: [group_id], references: [id])
  Lesson      Lesson?   @relation(fields: [lesson_id], references: [id])
  Teachers    Teachers? @relation(fields: [teacher_id], references: [id])
  User        User?     @relation(fields: [user_id], references: [id])
}

model qr_codes {
  id        String   @id
  type      String
  content   String
  qrDataUrl String
  label     String?
  createdAt DateTime @default(now())
}

enum GroupStatus {
  planned
  active
  completed
  cancelled
  freeze
}

enum Status {
  active
  inactive
  freeze
}

enum StudentStatus {
  active
  inactive
  freeze
  graduated
}

enum UserRole {
  SUPERADMIN
  ADMIN
  TEACHER
  STUDENT
}

enum WeekDay {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
  Sunday
}
